{
  "name": "bilingual-voice-commerce-assistant",
  "version": "1.0.0",
  "private": true,
  "description": "MERN implementation of a bilingual voice-driven e-commerce assistant for HCI CP submissions.",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon server/index.js",
    "server": "node server/index.js",
    "client:dev": "npm --prefix client run dev",
    "build": "npm --prefix client run build",
    "start": "node server/index.js",
    "evaluate": "node eval/evaluate.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mongoose": "^8.9.5"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.9"
  }
}
